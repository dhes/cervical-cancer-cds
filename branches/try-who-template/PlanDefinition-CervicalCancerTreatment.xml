      <code value="001"/>
    </coding>
  </jurisdiction>
  <purpose value="To guide treatment modality selection for women with HPV-positive, VIA-positive cervical pre-cancer, ensuring appropriate assessment of ablation eligibility and selection of the most suitable treatment method for the clinical setting."/>
